# Dependencies
/node_modules/
/.pnp
/.pnp.js
/.pnp.*

# Next.js output
/.next/
/out/
/build/

# Frontend env files
/.env
/.env.local
/.env.development
/.env.production
/.env.test

# Keep example env
!/.env.example

# Vercel
/.vercel/

